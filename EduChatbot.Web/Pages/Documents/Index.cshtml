@page
@model EduChatbot.Web.Pages.Documents.IndexModel
@{
    ViewData["Title"] = "Documents";
    var totalDocs = Model.Result.Documents.Count;
    var approvedDocs = Model.Result.Documents.Count(d => d.Status == EduChatbot.Models.DocumentStatuses.Approved);
    var processingDocs = Model.Result.Documents.Count(d => d.Status == EduChatbot.Models.DocumentStatuses.Processing);
    var failedDocs = Model.Result.Documents.Count(d => d.Status == EduChatbot.Models.DocumentStatuses.Failed || d.Status == EduChatbot.Models.DocumentStatuses.Rejected);
}

<style>
    /* Premium Lecturer Documents Page styles */
    .documents-stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2.5rem;
    }

    .documents-stat-card {
        background: #111827;
        border: 1px solid rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(10px);
        border-radius: 16px;
        padding: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1.25rem;
        transition: transform 0.2s ease-out, box-shadow 0.2s ease-out, border-color 0.2s ease;
    }

    .documents-stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 30px -10px rgba(0, 0, 0, 0.6);
        border-color: rgba(14, 165, 233, 0.3);
    }

    .documents-stat-card-icon-wrapper {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .icon-total {
        background: rgba(14, 165, 233, 0.1);
        color: #0ea5e9;
    }

    .icon-approved {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
    }

    .icon-processing {
        background: rgba(245, 158, 11, 0.1);
        color: #f59e0b;
    }

    .icon-failed {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
    }

    .documents-stat-card-label {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--edu-text-muted);
        margin-bottom: 0.25rem;
        line-height: 1.2;
    }

    .documents-stat-card-value {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--edu-text);
        line-height: 1.1;
    }

    /* Filter Toolbar */
    .documents-filter-card {
        background: #111827;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        padding: 1rem 1.5rem;
        margin-bottom: 2rem;
    }

    .documents-search-form {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        align-items: center;
        width: 100%;
    }

    .documents-search-input-wrapper {
        position: relative;
        flex-grow: 1;
        min-width: 260px;
    }

    .documents-search-icon {
        position: absolute;
        left: 0.85rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--edu-text-muted);
        font-size: 1rem;
    }

    .documents-search-input {
        width: 100%;
        background: #070B16;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 10px;
        padding: 0.6rem 1rem 0.6rem 2.25rem;
        font-size: 0.85rem;
        color: var(--edu-text);
        outline: none;
        transition: border-color 0.2s ease;
    }

    .documents-search-input:focus {
        border-color: rgba(14, 165, 233, 0.4);
    }

    .btn-search-submit {
        background: rgba(14, 165, 233, 0.1);
        border: 1px solid rgba(14, 165, 233, 0.25);
        color: #0ea5e9;
        font-weight: 700;
        font-size: 0.85rem;
        padding: 0.6rem 1.5rem;
        border-radius: 10px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-search-submit:hover {
        background: rgba(14, 165, 233, 0.2);
        color: #ffffff;
    }

    .btn-search-reset {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: var(--edu-text-muted);
        font-weight: 600;
        font-size: 0.85rem;
        padding: 0.6rem 1.25rem;
        border-radius: 10px;
        text-decoration: none;
        transition: all 0.2s ease;
        text-align: center;
    }

    .btn-search-reset:hover {
        background: rgba(255, 255, 255, 0.08);
        color: var(--edu-text);
    }

    /* Documents Table Layout */
    .documents-table-container-card {
        background: #111827;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        overflow: hidden;
        margin-bottom: 2.5rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .documents-table-header {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.015);
        font-size: 0.85rem;
        color: var(--edu-text-muted);
    }

    .documents-table-markup {
        width: 100%;
        border-collapse: collapse;
    }

    .documents-table-markup th {
        background: rgba(255, 255, 255, 0.02);
        color: var(--edu-text-muted);
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 1rem 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .documents-table-markup td {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        vertical-align: middle;
        color: var(--edu-text);
    }

    .documents-table-row {
        transition: background-color 0.2s ease;
    }

    .documents-table-row:hover {
        background-color: rgba(255, 255, 255, 0.015);
    }

    /* File column specific */
    .document-file-cell {
        display: flex;
        align-items: center;
        gap: 0.85rem;
    }

    .document-file-icon {
        font-size: 1.65rem;
        flex-shrink: 0;
    }

    .document-file-name {
        font-weight: 600;
        color: #ffffff;
        font-size: 0.9rem;
        line-height: 1.3;
    }

    .document-file-meta {
        font-size: 0.72rem;
        color: var(--edu-text-muted);
        margin-top: 0.15rem;
        font-family: monospace;
    }

    /* Status badges */
    .document-status-badge {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        font-size: 0.75rem;
        font-weight: 700;
        border-radius: 9999px;
        text-align: center;
        border: 1px solid transparent;
    }

    .document-status-approved {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
        border-color: rgba(16, 185, 129, 0.2);
    }

    .document-status-processing {
        background: rgba(245, 158, 11, 0.1);
        color: #f59e0b;
        border-color: rgba(245, 158, 11, 0.2);
    }

    .document-status-failed,
    .document-status-rejected {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
        border-color: rgba(239, 68, 68, 0.2);
    }

    /* Action Groups */
    .document-action-group {
        display: flex;
        gap: 0.5rem;
        justify-content: flex-end;
    }

    .document-action-btn {
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: var(--edu-text-muted);
        text-decoration: none;
        transition: all 0.2s ease;
        padding: 0;
        cursor: pointer;
    }

    .document-action-btn:hover {
        background: rgba(255, 255, 255, 0.08);
        color: var(--edu-primary);
        border-color: rgba(255, 255, 255, 0.2);
    }

    .document-action-btn.btn-delete:hover {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
        border-color: rgba(239, 68, 68, 0.3);
    }

    .course-badge-tag {
        font-size: 0.78rem;
        font-weight: 500;
        background: rgba(228, 240, 246, 0.06);
        border: 1px solid rgba(228, 240, 246, 0.10);
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        color: var(--edu-text);
        white-space: nowrap;
    }
</style>

@functions {
    string GetDocIconClass(string fileName)
    {
        if (string.IsNullOrEmpty(fileName)) return "bi-file-earmark-text text-muted";
        var ext = System.IO.Path.GetExtension(fileName).ToLower();
        if (ext == ".pdf") return "bi-file-earmark-pdf text-danger";
        if (ext == ".doc" || ext == ".docx") return "bi-file-earmark-word text-primary";
        if (ext == ".xls" || ext == ".xlsx") return "bi-file-earmark-excel text-success";
        if (ext == ".ppt" || ext == ".pptx") return "bi-file-earmark-ppt text-warning";
        return "bi-file-earmark-text text-muted";
    }
}

<section class="role-page">
    <!-- Page Header Section -->
    <header class="role-hero compact">
        <div>
            <div class="role-kicker" data-i18n="docs.courses.kicker">Courses</div>
            @if (Model.FilteredCourse != null)
            {
                <h1>[@Model.FilteredCourse.Code] @Model.FilteredCourse.Name</h1>
                <p>Showing documents for this course.</p>
            }
            else
            {
                <h1 data-i18n="docs.index.title">Learning Materials</h1>
                <p data-i18n="docs.index.desc">Search, inspect indexing status, and manage uploaded academic files.</p>
            }
        </div>
        <a asp-page="/Documents/Upload" style="text-decoration: none;" class="role-primary-btn" data-i18n="nav.uploadDocument">Upload document</a>
    </header>

    @if (Model.FilteredCourse != null)
    {
        <div style="margin-bottom: 2rem; display: flex; gap: 0.75rem;">
            <a asp-page="/Documents/Index" class="btn-search-reset" style="padding: 0.5rem 1rem;" data-i18n="docs.index.allDocs">← All documents</a>
            <a asp-page="/Documents/Dashboard" class="btn-search-reset" style="padding: 0.5rem 1rem;" data-i18n="docs.index.backDashboard">← Back to Dashboard</a>
        </div>
    }

    @if (TempData["UploadMessage"] != null)
    {
        <div class="role-alert success">
            <strong>@TempData["UploadMessage"]</strong>
            <span>@TempData["ChunkCount"] chunks, @TempData["IndexStatus"]</span>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="role-alert danger">@TempData["ErrorMessage"]</div>
    }

    <!-- Bento Stats Grid -->
    <div class="documents-stats-grid">
        <div class="documents-stat-card">
            <div class="documents-stat-card-icon-wrapper icon-total">
                <i class="bi bi-collection"></i>
            </div>
            <div>
                <div class="documents-stat-card-label" data-i18n="docs.index.totalDocuments">Total Documents</div>
                <div class="documents-stat-card-value">@totalDocs</div>
            </div>
        </div>
        <div class="documents-stat-card">
            <div class="documents-stat-card-icon-wrapper icon-approved">
                <i class="bi bi-check-circle"></i>
            </div>
            <div>
                <div class="documents-stat-card-label" data-i18n="docs.index.approvedDocuments">Approved Documents</div>
                <div class="documents-stat-card-value">@approvedDocs</div>
            </div>
        </div>
        <div class="documents-stat-card">
            <div class="documents-stat-card-icon-wrapper icon-processing">
                <i class="bi bi-hourglass-split"></i>
            </div>
            <div>
                <div class="documents-stat-card-label" data-i18n="docs.index.processingDocuments">Processing</div>
                <div class="documents-stat-card-value">@processingDocs</div>
            </div>
        </div>
        <div class="documents-stat-card">
            <div class="documents-stat-card-icon-wrapper icon-failed">
                <i class="bi bi-exclamation-triangle"></i>
            </div>
            <div>
                <div class="documents-stat-card-label" data-i18n="docs.index.failedDocuments">Failed / Rejected</div>
                <div class="documents-stat-card-value">@failedDocs</div>
            </div>
        </div>
    </div>

    <!-- Search Toolbar Card -->
    <div class="documents-filter-card">
        <form method="get" class="documents-search-form">
            @if (Model.FilteredCourse != null)
            {
                <input type="hidden" name="courseId" value="@Model.FilteredCourse.Id" />
            }
            <div class="documents-search-input-wrapper">
                <i class="bi bi-search documents-search-icon"></i>
                <input type="search" name="searchTerm" value="@Model.Result.SearchTerm" class="documents-search-input" placeholder="Search file name, lecturer, status..." data-i18n-placeholder="docs.index.searchPlaceholder" />
            </div>
            <button type="submit" class="btn-search-submit" data-i18n="nav.search">Search</button>
            <a asp-page="/Documents/Index" class="btn-search-reset" data-i18n="docs.index.reset">Reset</a>
        </form>
    </div>

    <!-- Documents List Table -->
    @if (!Model.Result.Documents.Any())
    {
        <div class="documents-table-container-card" style="padding: 4rem 2rem; text-align: center;">
            <div style="font-size: 3.5rem; color: rgba(255, 255, 255, 0.05); margin-bottom: 1.5rem;">
                <i class="bi bi-folder-x"></i>
            </div>
            <h4 class="fw-bold text-white mb-2" data-i18n="docs.index.noDocuments">No learning materials uploaded yet.</h4>
            <p class="text-muted mb-0" data-i18n="docs.index.uploadHint">
                Upload PDF or DOCX files to make them available for chatbot retrieval.
            </p>
        </div>
    }
    else
    {
        <div class="documents-table-container-card">
            <div class="documents-table-header">
                <i class="bi bi-folder2-open me-2"></i>
                <span data-i18n="admin.courses.courseList">List Courses</span> · @Model.Result.TotalCount <span data-i18n="nav.documents">documents</span>
            </div>
            <div class="table-responsive">
                <table class="documents-table-markup align-middle mb-0">
                    <thead>
                        <tr>
                            <th style="width: 30%;">File Name</th>
                            <th data-i18n="docs.index.course" style="width: 20%;">Course</th>
                            <th style="width: 15%;">Lecturer</th>
                            <th style="text-align: center; width: 10%;">Size</th>
                            <th style="text-align: center; width: 10%;">Chunks</th>
                            <th style="width: 10%;">Status</th>
                            <th style="text-align: right; padding-right: 1.5rem; width: 5%;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var document in Model.Result.Documents)
                        {
                            var sizeMb = document.FileSize / 1024d / 1024d;
                            var courseInfo = !string.IsNullOrWhiteSpace(document.SubjectCode)
                                ? $"[{document.SubjectCode}] {document.SubjectName}"
                                : document.Course != null ? $"[{document.Course.Code}] {document.Course.Name}" : "N/A";
                            var statusClass = "document-status-failed";
                            if (document.Status == EduChatbot.Models.DocumentStatuses.Approved)
                            {
                                statusClass = "document-status-approved";
                            }
                            else if (document.Status == EduChatbot.Models.DocumentStatuses.Processing)
                            {
                                statusClass = "document-status-processing";
                            }
                            else if (document.Status == EduChatbot.Models.DocumentStatuses.Rejected)
                            {
                                statusClass = "document-status-rejected";
                            }

                            <tr class="documents-table-row">
                                <td>
                                    <div class="document-file-cell">
                                        <i class="bi @GetDocIconClass(document.FileName) document-file-icon"></i>
                                        <div>
                                            <div class="document-file-name" title="@document.FileName">@document.FileName</div>
                                            <div class="document-file-meta">ID: @document.Id · @document.UploadedAt.ToString("dd/MM/yyyy HH:mm")</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="course-badge-tag">@courseInfo</span>
                                </td>
                                <td>
                                    <span style="font-size: 0.85rem; color: var(--edu-text);">@document.UploadedBy</span>
                                </td>
                                <td style="text-align: center; font-size: 0.85rem; color: var(--edu-text-muted);">
                                    @sizeMb.ToString("0.00") MB
                                </td>
                                <td style="text-align: center; font-size: 0.85rem; font-weight: 600; color: #ffffff;">
                                    @document.ChunkCount
                                </td>
                                <td>
                                    <span class="document-status-badge @statusClass">@document.Status</span>
                                </td>
                                <td style="text-align: right; padding-right: 1.5rem;">
                                    <div class="document-action-group">
                                        <a href="@document.FilePath" target="_blank" class="document-action-btn" title="Open PDF/File">
                                            <i class="bi bi-file-earmark-arrow-down"></i>
                                        </a>
                                        <a asp-page="/Documents/Details" asp-route-id="@document.Id" class="document-action-btn" title="Details">
                                            <i class="bi bi-info-circle"></i>
                                        </a>
                                        <a asp-page="/Documents/Edit" asp-route-id="@document.Id" class="document-action-btn" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@document.Id" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this document and all its chunks?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="document-action-btn btn-delete" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</section>
