@page
@model EduChatbot.Web.Pages.Documents.DashboardModel

@{
    ViewData["Title"] = "Dashboard";
}

<section class="role-page">
    <header class="role-hero">
        <div>
            <div class="role-kicker">Lecturer workspace</div>
            <h1>Dashboard</h1>
            <p>Manage your assigned courses and academic documents.</p>
        </div>
        <a asp-page="/Documents/Upload" class="role-primary-btn">Upload document</a>
    </header>

    <!-- ===== Assigned Courses ===== -->
    <div class="role-section-header">
        <h2>My Assigned Courses</h2>
        <span>@Model.AssignedCourses.Count course(s)</span>
    </div>

    @if (Model.AssignedCourses.Count == 0)
    {
        <div class="role-empty-panel">
            <strong>No courses assigned yet.</strong>
            <span>Contact an administrator to be assigned to courses.</span>
        </div>
    }
    else
    {
        <div class="role-course-grid">
            @foreach (var course in Model.AssignedCourses)
            {
                <article class="role-course-card">
                    <div class="role-course-header">
                        <span class="role-course-code">@course.Code</span>
                    </div>
                    <h3 class="role-course-name">@course.Name</h3>
                    <p class="role-course-desc">
                        @(string.IsNullOrWhiteSpace(course.Description) ? "No description available." : course.Description)
                    </p>
                    <a asp-page="/Documents/Index" asp-route-courseId="@course.Id" class="role-course-link">
                        View Details <span aria-hidden="true">→</span>
                    </a>
                </article>
            }
        </div>
    }

    <!-- ===== Document Statistics ===== -->
    <div class="role-section-header" style="margin-top: 3rem;">
        <h2>Document Statistics</h2>
    </div>

    <div class="role-stat-grid">
        <article class="role-stat-card">
            <span>Total documents</span>
            <strong>@Model.Summary.TotalDocuments</strong>
        </article>
        <article class="role-stat-card success">
            <span>Indexed documents</span>
            <strong>@Model.Summary.ReadyDocuments</strong>
        </article>
        <article class="role-stat-card danger">
            <span>Rejected/Failed</span>
            <strong>@Model.Summary.FailedDocuments</strong>
        </article>
        <article class="role-stat-card accent">
            <span>Total chunks</span>
            <strong>@Model.Summary.TotalChunks</strong>
        </article>
    </div>

    <div class="role-action-grid">
        <article class="role-panel role-panel-large">
            <div class="role-panel-label">Management</div>
            <h2>Review indexed materials</h2>
            <p data-i18n="docs.dashboard.viewFull">View complete list, check chunk data, and manage uploaded academic materials.</p>
            <a asp-page="/Documents/Index" class="role-secondary-btn">View documents</a>
        </article>

        <a asp-page="/Documents/Upload" class="role-upload-callout">
            <span>Upload</span>
            <strong data-i18n="docs.dashboard.addNew">Add new document</strong>
            <small data-i18n="docs.dashboard.fileFormats">PDF, DOCX, maximum 10 MB</small>
        </a>
    </div>
</section>

