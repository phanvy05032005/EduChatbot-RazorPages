@inject Microsoft.AspNetCore.Identity.UserManager<EduChatbot.Models.Identity.ApplicationUser> UserManager
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
    var currentPath = Context.Request.Path.Value ?? "";
    var isSubscriptionActive = currentPath.StartsWith("/Subscription", StringComparison.OrdinalIgnoreCase);
    var appUser = await UserManager.GetUserAsync(User);
    var displayName = !string.IsNullOrWhiteSpace(appUser?.FullName)
        ? appUser.FullName
        : appUser?.Email ?? "Student";
    var email = appUser?.Email ?? "";
    var avatarInitial = !string.IsNullOrWhiteSpace(displayName)
        ? displayName.Trim()[0].ToString().ToUpper()
        : "S";
}
<aside class="student-sidebar d-flex flex-column py-4 px-3">
    <!-- Brand Header -->
    <div class="brand-header d-flex align-items-center justify-content-between px-2 mb-4">
        <div class="d-flex align-items-center gap-2">
            <div class="brand-logo bg-primary text-white d-flex align-items-center justify-content-center shadow rounded-3" style="width: 40px; height: 40px;">
                <i class="bi bi-mortarboard fs-4"></i>
            </div>
            <div>
                <h1 class="brand-title fs-5 mb-0 fw-bold">EduChatbot</h1>
                <p class="brand-subtitle text-muted mb-0" style="font-size: 0.8rem;">Academic Assistant</p>
            </div>
        </div>
        <button type="button" class="btn-close d-lg-none" id="sidebarClose" aria-label="Close"></button>
    </div>

    <!-- Sidebar Menu Links -->
    <nav class="sidebar-nav flex-grow-1 d-flex flex-column gap-1 overflow-y-auto custom-scrollbar">
        <a class="nav-item d-flex align-items-center gap-3 px-3 py-2 rounded-3 @(currentPage.Equals("/Student/Index", StringComparison.OrdinalIgnoreCase) ? "active" : "")" 
           asp-page="/Student/Index">
            <i class="bi bi-speedometer2 fs-5"></i>
            <span data-i18n="student.sidebar.dashboard">Dashboard</span>
        </a>
        <a class="nav-item d-flex align-items-center gap-3 px-3 py-2 rounded-3 @(currentPage.Equals("/Student/Chat", StringComparison.OrdinalIgnoreCase) ? "active" : "")" 
           asp-page="/Student/Chat">
            <i class="bi bi-chat-right-text fs-5"></i>
            <span data-i18n="student.sidebar.newchat">New Chat</span>
        </a>
        <a class="nav-item d-flex align-items-center gap-3 px-3 py-2 rounded-3 @(currentPage.Equals("/Student/ChatHistory", StringComparison.OrdinalIgnoreCase) ? "active" : "")" 
           asp-page="/Student/ChatHistory">
            <i class="bi bi-clock-history fs-5"></i>
            <span data-i18n="student.sidebar.chathistory">Chat History</span>
        </a>
        <a class="nav-item d-flex align-items-center gap-3 px-3 py-2 rounded-3 @(currentPage.Equals("/Student/Courses", StringComparison.OrdinalIgnoreCase) || currentPage.Equals("/Student/CourseDetail", StringComparison.OrdinalIgnoreCase) ? "active" : "")" 
           asp-page="/Student/Courses">
            <i class="bi bi-book fs-5"></i>
            <span data-i18n="student.sidebar.courses">Courses</span>
        </a>
        <a class="nav-item d-flex align-items-center gap-3 px-3 py-2 rounded-3 @(currentPage.Equals("/Student/Documents", StringComparison.OrdinalIgnoreCase) ? "active" : "")" 
           asp-page="/Student/Documents">
            <i class="bi bi-file-earmark-text fs-5"></i>
            <span data-i18n="student.sidebar.documents">Documents</span>
        </a>
        <a class="nav-item d-flex align-items-center gap-3 px-3 py-2 rounded-3 @(currentPage.StartsWith("/Student/Quizzes", StringComparison.OrdinalIgnoreCase) ? "active" : "")" 
           asp-page="/Student/Quizzes/Index">
            <i class="bi bi-patch-question fs-5"></i>
            <span data-i18n="student.sidebar.quizzes">Quizzes</span>
        </a>
        <a class="nav-item d-flex align-items-center gap-3 px-3 py-2 rounded-3 @(isSubscriptionActive ? "active" : "")"
           asp-page="/Subscription/Plans">
            <i class="bi bi-stars fs-5"></i>
            <span data-i18n="student.sidebar.subscription">Subscription</span>
        </a>
    </nav>

    <!-- Sidebar User Footer -->
    <div class="sidebar-footer pt-3 mt-auto border-top">
        <div class="d-flex align-items-center gap-2 mb-3">
            <div class="user-avatar bg-primary-subtle text-primary d-flex align-items-center justify-content-center fw-bold rounded-3" style="width: 40px; height: 40px;">
                @avatarInitial
            </div>
            <div class="user-info overflow-hidden">
                <p class="user-name mb-0 fw-semibold text-truncate" style="font-size: 0.9rem;">@displayName</p>
                <p class="user-email mb-0 text-muted text-truncate" style="font-size: 0.75rem;">@email</p>
            </div>
        </div>



        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
            <button type="submit" class="btn btn-outline-danger w-100 d-flex align-items-center justify-content-center gap-2 rounded-3 py-2 btn-sm">
                <i class="bi bi-box-arrow-right fs-6"></i>
                <span data-i18n="student.sidebar.logout">Sign Out</span>
            </button>
        </form>
    </div>
</aside>
