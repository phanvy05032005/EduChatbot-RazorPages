@inject Microsoft.AspNetCore.Identity.UserManager<EduChatbot.Models.Identity.ApplicationUser> UserManager
@{
    var extraBodyClass = ViewData["BodyClass"] as string;
    var isAdminUser = User.IsInRole("Admin");
    var bodyClass = string.IsNullOrWhiteSpace(extraBodyClass)
        ? "app-shell"
        : $"app-shell {extraBodyClass}";
    if (isAdminUser)
    {
        bodyClass += " admin-layout";
    }
    var isChatLayout = extraBodyClass?.Contains("chat-layout") == true;

    var userNeedsPasswordChange = false;
    EduChatbot.Models.Identity.ApplicationUser? appUser = null;
    if (User.Identity?.IsAuthenticated == true && (User.IsInRole("Student") || User.IsInRole("Lecturer")))
    {
        appUser = await UserManager.GetUserAsync(User);
        if (appUser != null && !appUser.HasChangedPassword)
        {
            userNeedsPasswordChange = true;
        }
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduChatbot</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@1,9..144,400;1,9..144,500&family=JetBrains+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @if (isChatLayout)
    {
        <script>
            (function () {
                try {
                    if (localStorage.getItem('eduChatbot.sidebarCollapsed') === 'true') {
                        document.documentElement.classList.add('chat-sidebar-collapsed-persisted');
                    }
                } catch {
                }
            })();
        </script>
        <link rel="stylesheet" href="~/css/chat.css" asp-append-version="true" />
    }
    <link rel="stylesheet" href="~/EduChatbot.Web.styles.css" asp-append-version="true" />
</head>
<body class="@bodyClass">
    @if (userNeedsPasswordChange)
    {
        <!-- Password Change Top persistent banner -->
        <div id="pwdCornerBanner" class="pwd-corner-banner">
            <div class="pwd-corner-banner-content">
                <span class="pwd-corner-banner-icon">⚠️</span>
                <span class="pwd-corner-banner-text">
                    <strong data-i18n="pwd.banner.title">Password Change Required</strong>: 
                    <span data-i18n="pwd.banner.desc">You haven't changed your default password. Click here to change your password now.</span>
                </span>
                <button type="button" class="pwd-corner-banner-action" data-i18n="pwd.banner.action">Change Now</button>
            </div>
        </div>
    }
@if (User.IsInRole("Admin"))
{
    <div class="admin-shell">
        <aside class="admin-sidebar">
            <div class="admin-brand">
                <span class="admin-brand-mark" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M3.5 8.7 12 4.4l8.5 4.3-8.5 4.2-8.5-4.2Z" />
                        <path d="M6.5 10.4v4.4c1.7 1.3 3.5 1.9 5.5 1.9s3.8-.6 5.5-1.9v-4.4" />
                        <path d="M20.5 8.7v5.8" />
                    </svg>
                </span>
                <div>
                    <strong>EduChatbot</strong>
                    <small>ADMIN</small>
                </div>
            </div>
            <nav class="admin-menu">
                <a asp-page="/Admin/Dashboard" class="admin-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Admin/Dashboard" ? "active" : "")">
                    <span class="admin-menu-icon">▦</span>
                    <span data-i18n="admin.sidebar.dashboard">Dashboard</span>
                </a>
                @{
                    var currentPage = ViewContext.RouteData.Values["page"]?.ToString();
                    var isUsersActive = currentPage == "/Admin/Users" || currentPage == "/Admin/Students" || currentPage == "/Admin/Lecturers";
                }
                <a asp-page="/Admin/Users" class="admin-link @(isUsersActive ? "active" : "")">
                    <span class="admin-menu-icon">👤</span>
                    <span data-i18n="admin.sidebar.users">Users</span>
                </a>
                <a asp-page="/Admin/Courses" class="admin-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Admin/Courses" ? "active" : "")">
                    <span class="admin-menu-icon">📚</span>
                    <span data-i18n="admin.sidebar.coursesAssignments">Courses &amp; Assignments</span>
                </a>
                <a asp-page="/Admin/Roles" class="admin-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Admin/Roles" ? "active" : "")">
                    <span class="admin-menu-icon">◇</span>
                    <span data-i18n="admin.sidebar.roleManagement">Role Management</span>
                </a>
                <a asp-page="/Admin/System" class="admin-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Admin/System" ? "active" : "")">
                    <span class="admin-menu-icon">▭</span>
                    <span data-i18n="admin.sidebar.systemManagement">System Management</span>
                </a>
                <a asp-page="/Admin/Statistics" class="admin-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Admin/Statistics" ? "active" : "")">
                    <span class="admin-menu-icon">▥</span>
                    <span data-i18n="admin.sidebar.statistics">Statistics</span>
                </a>
            </nav>
            <form asp-page="/Account/Logout" method="post" class="admin-logout">
                @Html.AntiForgeryToken()
                <button type="submit">
                    <span class="admin-menu-icon">↳</span>
                    <span data-i18n="admin.sidebar.logout">Logout</span>
                </button>
            </form>
        </aside>
        <div class="admin-content">
            <header class="admin-topbar">
                <div class="admin-breadcrumb">
                    <span>EDUCHATBOT · ADMIN</span>
                    <i aria-hidden="true">/</i>
                    <strong>@ViewData["Title"]</strong>
                </div>
                <div class="admin-user-wrap">
                    <button type="button" class="lang-toggle-btn" onclick="EduI18n.toggle()" title="Switch language" style="background: rgba(228,240,246,0.08); border: 1px solid rgba(228,240,246,0.15); color: #e4f0f6; border-radius: 6px; padding: 0.35rem 0.65rem; font-size: 0.78rem; font-weight: 700; cursor: pointer; letter-spacing: 0.5px; margin-right: 1rem;">VI</button>
                    <div class="admin-user">
                        <span aria-hidden="true"></span>
                        @User.Identity?.Name
                    </div>
                    <div class="admin-avatar">A</div>
                </div>
            </header>
            <main role="main" class="admin-main">
                @RenderBody()
            </main>
        </div>
    </div>
}
else
{
    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Lecturer"))
    {
        <div class="role-shell">
            <aside class="role-sidebar">
                <div class="role-brand">
                    <span class="role-brand-mark">LE</span>
                    <div>
                        <strong>EduChatbot</strong>
                        <small>Lecturer Portal</small>
                    </div>
                </div>
                <nav class="role-menu">
                    @{
                        var currentRolePage = ViewContext.RouteData.Values["page"]?.ToString();
                        var isDashboardActive = currentRolePage == "/Documents/Dashboard";
                    }
                    <a asp-page="/Documents/Dashboard" data-i18n="nav.dashboard" class="@(isDashboardActive ? "active" : "")">Dashboard</a>
                    <a asp-page="/Documents/Courses" data-i18n="nav.allCourses" class="@(currentRolePage == "/Documents/Courses" ? "active" : "")">All Courses</a>
                    <a asp-page="/Documents/Index" data-i18n="nav.learningMaterials" class="@(currentRolePage == "/Documents/Index" ? "active" : "")">Learning Materials</a>
                    <a asp-page="/Documents/Upload" data-i18n="nav.uploadDocument" class="@(currentRolePage == "/Documents/Upload" ? "active" : "")">Upload Document</a>
                    <a asp-page="/Lecturer/Quizzes/Index" data-i18n="nav.quizzesManagement" class="@(currentRolePage != null && currentRolePage.StartsWith("/Lecturer/Quizzes") ? "active" : "")">Quizzes Management</a>
                    <a asp-page="/Account/Profile" data-i18n="nav.profile" class="@(currentRolePage == "/Account/Profile" ? "active" : "")">Profile</a>
                </nav>
                <form asp-page="/Account/Logout" method="post" class="role-logout">
                    @Html.AntiForgeryToken()
                    <button type="submit" data-i18n="nav.logout">Logout</button>
                </form>
            </aside>
            <div class="role-content">
                <header class="role-topbar">
                    <div>
                        <span>Academic Chatbot System</span>
                        <strong>@ViewData["Title"]</strong>
                    </div>
                    <div style="display: flex; align-items: center; gap: 1rem;">
                        <button type="button" class="lang-toggle-btn" onclick="EduI18n.toggle()" title="Switch language" style="background: rgba(0, 102, 204, 0.08); border: 1px solid rgba(0, 102, 204, 0.15); color: #0066cc; border-radius: 6px; padding: 0.35rem 0.65rem; font-size: 0.78rem; font-weight: 700; cursor: pointer; letter-spacing: 0.5px;">VI</button>
                        
                        <div class="lecturer-account-dropdown">
                            @{
                                var displayName = !string.IsNullOrWhiteSpace(appUser?.FullName) ? appUser.FullName : (appUser?.Email ?? User.Identity?.Name ?? "Lecturer");
                                var emailDisplay = appUser?.Email ?? User.Identity?.Name ?? "";
                                var avatarInitial = !string.IsNullOrWhiteSpace(displayName) ? displayName.Trim()[0].ToString().ToUpper() : "L";
                            }
                            <button type="button" class="lecturer-account-trigger" id="lecturerAccountTrigger" aria-haspopup="true" aria-expanded="false">
                                <span class="lecturer-account-avatar">@avatarInitial</span>
                                <span class="lecturer-account-name d-none d-md-inline">@displayName</span>
                                <i class="bi bi-chevron-down lecturer-account-caret"></i>
                            </button>
                            <div class="lecturer-account-menu" id="lecturerAccountMenu">
                                <div class="lecturer-account-menu-header">
                                    <div class="lecturer-menu-header-avatar">@avatarInitial</div>
                                    <div class="lecturer-menu-header-info">
                                        <div class="lecturer-menu-header-name">@displayName</div>
                                        <div class="lecturer-menu-header-email">@emailDisplay</div>
                                        <span class="lecturer-menu-header-badge" data-i18n="profile.lecturerAccount">Lecturer Account</span>
                                    </div>
                                </div>
                                <div class="lecturer-account-menu-divider"></div>
                                <a asp-page="/Account/Profile" class="lecturer-account-menu-item">
                                    <i class="bi bi-person-fill"></i>
                                    <span data-i18n="profile.personalInfo">View Profile</span>
                                </a>
                                <a asp-page="/Account/Profile" class="lecturer-account-menu-item">
                                    <i class="bi bi-pencil-square"></i>
                                    <span data-i18n="profile.updateProfile">Edit Profile</span>
                                </a>
                                <a asp-page="/Account/Profile" class="lecturer-account-menu-item">
                                    <i class="bi bi-shield-lock-fill"></i>
                                    <span data-i18n="profile.changePassword">Change Password</span>
                                </a>
                                <a asp-page="/Documents/Dashboard" class="lecturer-account-menu-item">
                                    <i class="bi bi-speedometer2"></i>
                                    <span data-i18n="nav.dashboard">Dashboard</span>
                                </a>
                                <div class="lecturer-account-menu-divider"></div>
                                <form asp-page="/Account/Logout" method="post" class="lecturer-logout-form-dropdown">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="lecturer-account-menu-item danger">
                                        <i class="bi bi-box-arrow-right"></i>
                                        <span data-i18n="nav.logout">Logout</span>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </header>
                <main role="main" class="role-main">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom mb-4">
            <div class="container">
                <a class="navbar-brand fw-semibold" asp-area="" asp-page="/Documents/Dashboard">EduChatbot</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.IsInRole("Student"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Chat/Index" data-i18n="nav.chat">Chat</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Account/Profile" data-i18n="nav.profile">Profile</a>
                            </li>
                        }
                        @if (User.IsInRole("Lecturer"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Documents/Dashboard" data-i18n="nav.dashboard">Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Documents/Index" data-i18n="nav.learningMaterials">Documents</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Documents/Upload" data-i18n="nav.uploadDocument">Upload</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Lecturer/Quizzes/Index" data-i18n="nav.quizzes">Quizzes</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item d-flex align-items-center me-3">
                            <button type="button" class="lang-toggle-btn btn btn-sm btn-outline-secondary" onclick="EduI18n.toggle()" title="Switch language" style="font-size: 0.78rem; font-weight: 700; padding: 0.25rem 0.5rem; letter-spacing: 0.5px;">VI</button>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link">@User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <form asp-page="/Account/Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link nav-link" data-i18n="nav.logout">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Account/Login" data-i18n="nav.login">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    }
}

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/i18n.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (User.IsInRole("Admin") || User.IsInRole("Lecturer"))
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    }
    @if (User.IsInRole("Admin"))
    {
        <script src="~/js/admin-realtime.js" asp-append-version="true"></script>
    }
    @if (User.IsInRole("Lecturer"))
    {
        <script src="~/js/lecturer-realtime.js" asp-append-version="true"></script>
    }

    @if (userNeedsPasswordChange)
    {
        <!-- Password Change Modal Overlay -->
        <div id="pwdChangeOverlay" class="pwd-modal-overlay">
            <div class="pwd-modal-box">
                <div class="pwd-modal-header">
                    <h3 data-i18n="pwd.modal.title">Change Your Password</h3>
                    <p data-i18n="pwd.modal.desc">Your account was created by the administrator. Please update your password to continue securely.</p>
                </div>
                <div class="pwd-modal-body">
                    <div id="pwdModalError" class="pwd-modal-error"></div>
                    <form id="pwdChangeForm" method="post" action="/Account/Profile?handler=ChangePasswordAjax">
                        @Html.AntiForgeryToken()
                        <div class="form-group">
                            <label for="modalCurrentPassword" data-i18n="pwd.modal.currentPassword">Current Password</label>
                            <div class="pwd-input-wrapper">
                                <input type="password" id="modalCurrentPassword" name="currentPassword" class="form-control" placeholder="••••••••" required autocomplete="current-password" />
                                <button type="button" class="pwd-toggle-btn" title="Show password" aria-label="Toggle password visibility">
                                    <svg class="eye-open" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                                        <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
                                        <circle cx="12" cy="12" r="3"/>
                                    </svg>
                                    <svg class="eye-closed" style="display:none;" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                                        <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/>
                                        <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/>
                                        <path d="M6.61 6.61A13.52 13.52 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/>
                                        <line x1="2" x2="22" y1="2" y2="22"/>
                                    </svg>
                                </button>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="modalNewPassword" data-i18n="pwd.modal.newPassword">New Password</label>
                            <div class="pwd-input-wrapper">
                                <input type="password" id="modalNewPassword" name="newPassword" class="form-control" placeholder="••••••••" required autocomplete="new-password" />
                                <button type="button" class="pwd-toggle-btn" title="Show password" aria-label="Toggle password visibility">
                                    <svg class="eye-open" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                                        <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
                                        <circle cx="12" cy="12" r="3"/>
                                    </svg>
                                    <svg class="eye-closed" style="display:none;" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                                        <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/>
                                        <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/>
                                        <path d="M6.61 6.61A13.52 13.52 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/>
                                        <line x1="2" x2="22" y1="2" y2="22"/>
                                    </svg>
                                </button>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="modalConfirmPassword" data-i18n="pwd.modal.confirmPassword">Confirm New Password</label>
                            <div class="pwd-input-wrapper">
                                <input type="password" id="modalConfirmPassword" name="confirmPassword" class="form-control" placeholder="••••••••" required autocomplete="new-password" />
                                <button type="button" class="pwd-toggle-btn" title="Show password" aria-label="Toggle password visibility">
                                    <svg class="eye-open" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                                        <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
                                        <circle cx="12" cy="12" r="3"/>
                                    </svg>
                                    <svg class="eye-closed" style="display:none;" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                                        <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/>
                                        <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/>
                                        <path d="M6.61 6.61A13.52 13.52 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/>
                                        <line x1="2" x2="22" y1="2" y2="22"/>
                                    </svg>
                                </button>
                            </div>
                        </div>
                        <div class="pwd-modal-footer">
                            <button type="button" id="pwdCancelBtn" class="pwd-modal-btn pwd-modal-btn-cancel" data-i18n="pwd.modal.cancel">Cancel</button>
                            <button type="submit" class="pwd-modal-btn pwd-modal-btn-submit" data-i18n="pwd.modal.save">Change Password</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>


        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const overlay = document.getElementById("pwdChangeOverlay");
                const banner = document.getElementById("pwdCornerBanner");
                const cancelBtn = document.getElementById("pwdCancelBtn");
                const form = document.getElementById("pwdChangeForm");
                const errorDiv = document.getElementById("pwdModalError");

                if (!overlay || !banner) return;

                // Toggle password visibility
                const toggleButtons = form.querySelectorAll(".pwd-toggle-btn");
                toggleButtons.forEach(button => {
                    button.addEventListener("click", function () {
                        const input = this.parentElement.querySelector("input");
                        if (!input) return;
                        
                        const eyeOpen = this.querySelector(".eye-open");
                        const eyeClosed = this.querySelector(".eye-closed");
                        
                        if (input.type === "password") {
                            input.type = "text";
                            if (eyeOpen) eyeOpen.style.display = "none";
                            if (eyeClosed) eyeClosed.style.display = "block";
                            this.title = "Hide password";
                        } else {
                            input.type = "password";
                            if (eyeOpen) eyeOpen.style.display = "block";
                            if (eyeClosed) eyeClosed.style.display = "none";
                            this.title = "Show password";
                        }
                    });
                });

                // Check if dismissed in this session
                const isDismissed = sessionStorage.getItem("passwordModalDismissed") === "true";
                if (isDismissed) {
                    banner.classList.add("active");
                } else {
                    overlay.classList.add("active");
                }

                // Cancel button click handler
                cancelBtn.addEventListener("click", function (e) {
                    e.stopPropagation();
                    overlay.classList.remove("active");
                    sessionStorage.setItem("passwordModalDismissed", "true");
                    banner.classList.add("active");
                });

                // Banner Action button click handler (opens the modal)
                const actionBtn = banner.querySelector(".pwd-corner-banner-action");
                if (actionBtn) {
                    actionBtn.addEventListener("click", function (e) {
                        e.stopPropagation();
                        banner.classList.remove("active");
                        overlay.classList.add("active");
                    });
                }

                // Form submit handler
                form.addEventListener("submit", function (e) {
                    e.preventDefault();
                    errorDiv.style.display = "none";
                    errorDiv.textContent = "";

                    const currentPassword = document.getElementById("modalCurrentPassword").value;
                    const newPassword = document.getElementById("modalNewPassword").value;
                    const confirmPassword = document.getElementById("modalConfirmPassword").value;

                    if (!currentPassword || !newPassword || !confirmPassword) {
                        errorDiv.textContent = window.EduI18n ? window.EduI18n.t("pwd.modal.errorFillAll") : "Please fill in all fields.";
                        errorDiv.style.display = "block";
                        return;
                    }

                    if (newPassword !== confirmPassword) {
                        errorDiv.textContent = window.EduI18n ? window.EduI18n.t("pwd.modal.errorMatch") : "New password and confirmation password do not match.";
                        errorDiv.style.display = "block";
                        return;
                    }

                    const formData = new FormData(form);
                    
                    fetch(form.action || "/Account/Profile?handler=ChangePasswordAjax", {
                        method: "POST",
                        body: new URLSearchParams(formData)
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            // Success state
                            errorDiv.style.color = "#16a34a";
                            errorDiv.style.backgroundColor = "#f0fdf4";
                            errorDiv.style.borderColor = "#bbf7d0";
                            errorDiv.textContent = window.EduI18n ? window.EduI18n.t("profile.updateSuccess") : data.message;
                            errorDiv.style.display = "block";
                            
                            // Clear inputs
                            form.reset();
                            
                            // Wait and reload
                            setTimeout(function () {
                                location.reload();
                            }, 1500);
                        } else {
                            errorDiv.style.color = ""; // Restore defaults
                            errorDiv.style.backgroundColor = "";
                            errorDiv.style.borderColor = "";
                            errorDiv.textContent = data.message;
                            errorDiv.style.display = "block";
                        }
                    })
                    .catch(err => {
                        console.error("Change password error:", err);
                        errorDiv.textContent = "An error occurred. Please try again.";
                        errorDiv.style.display = "block";
                    });
                });
            });
        </script>
    }

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const trigger = document.getElementById("lecturerAccountTrigger");
            const menu = document.getElementById("lecturerAccountMenu");
            
            if (trigger && menu) {
                trigger.addEventListener("click", function (e) {
                    e.stopPropagation();
                    const isShown = menu.classList.contains("show");
                    if (isShown) {
                        menu.classList.remove("show");
                        trigger.setAttribute("aria-expanded", "false");
                    } else {
                        menu.classList.add("show");
                        trigger.setAttribute("aria-expanded", "true");
                    }
                });
                
                document.addEventListener("click", function (e) {
                    if (!trigger.contains(e.target) && !menu.contains(e.target)) {
                        menu.classList.remove("show");
                        trigger.setAttribute("aria-expanded", "false");
                    }
                });
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
