@page
@model EduChatbot.Web.Pages.Subscription.PlansModel

@{
    ViewData["Title"] = "Subscription Plans";
    ViewData["BodyClass"] = "student-profile";
}

<link rel="stylesheet" href="~/css/subscription.css" asp-append-version="true" />

<section class="sub-page">
    <header class="sub-hero">
        <div class="sub-kicker">Subscription</div>
        <h1>Chọn gói phù hợp với bạn</h1>
        <p>Nâng cấp lên Premium để mở khóa Quiz, tăng token limit và trải nghiệm đầy đủ hệ thống.</p>
        <div style="margin-top: 1.25rem;">
            <a asp-page="/Subscription/Me" class="sub-link-btn" style="display: inline-flex; align-items: center; gap: 0.5rem; text-decoration: none; padding: 0.5rem 1rem; border-radius: 6px; background: rgba(255,255,255,0.1); color: #fff; font-size: 0.9rem; font-weight: 500; border: 1px solid rgba(255,255,255,0.15); transition: background 0.2s;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                Xem gói dịch vụ của tôi
            </a>
        </div>
    </header>

    @if (TempData["SubMessage"] != null)
    {
        var msgType = TempData["SubMessageType"]?.ToString() ?? "warning";
        <div class="sub-alert @msgType">
            @if (msgType == "warning")
            {
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
            }
            else
            {
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            }
            <strong>@TempData["SubMessage"]</strong>
        </div>
    }

    <div class="sub-plans-grid">
        @foreach (var plan in Model.Plans)
        {
            var isBasic = plan.Type == "BASIC";
            var isPremium = plan.Type == "PREMIUM";

            <div class="sub-plan-card @(isPremium ? "is-premium" : "")">

                <h3 class="sub-plan-name">@plan.Name</h3>

                <div class="sub-plan-price">
                    @if (isBasic)
                    {
                        <strong>Miễn phí</strong>
                    }
                    else
                    {
                        <strong>@plan.Price.ToString("N0")</strong>
                        <span> @plan.Currency @(plan.DurationDays.HasValue ? $"/ {plan.DurationDays.Value} ngày" : "")</span>
                    }
                </div>

                <ul class="sub-plan-features">
                    <li>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        @plan.RequestLimit lượt hỏi / @(plan.RefreshIntervalMinutes == 1440 ? "ngày" : plan.RefreshIntervalMinutes + " phút")
                    </li>
                    <li>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        Hỗ trợ học tập qua Chat AI
                    </li>
                    @if (plan.QuizUnlocked)
                    {
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            Mở khóa Quiz
                        </li>
                    }
                    else
                    {
                        <li class="locked">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                            Quiz bị khóa
                        </li>
                    }
                </ul>

                <div class="sub-plan-action">
                    @if (isBasic)
                    {
                        @if (plan.Current)
                        {
                            <div class="sub-already-badge">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                Gói hiện tại (Còn @plan.RemainingRequests/@plan.RequestLimit lượt)
                            </div>
                        }
                    }
                    else if (isPremium)
                    {
                        @if (plan.Current)
                        {
                            <div class="sub-already-badge">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                Bạn đã là Premium (Còn @plan.RemainingRequests/@plan.RequestLimit lượt)
                            </div>
                        }
                        else
                        {
                            <form method="post" asp-page-handler="CreatePremiumPayment" class="sub-upgrade-form">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="sub-upgrade-btn" id="btn-upgrade-premium" data-default-text="Nâng cấp Premium" data-loading-text="Đang chuyển tới PayOS...">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
                                    <span>Nâng cấp Premium</span>
                                </button>
                            </form>
                        }
                    }
                </div>
            </div>
        }
    </div>
</section>

<script>
    (() => {
        const form = document.querySelector('.sub-upgrade-form');
        const button = document.querySelector('#btn-upgrade-premium');

        if (!form || !button) {
            return;
        }

        form.addEventListener('submit', () => {
            if (button.disabled) {
                return;
            }

            button.disabled = true;
            button.setAttribute('aria-busy', 'true');
            const text = button.querySelector('span');
            if (text) {
                text.textContent = button.dataset.loadingText || 'Đang xử lý...';
            }
        });
    })();
</script>
