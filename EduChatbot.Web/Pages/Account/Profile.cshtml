@page
@model EduChatbot.Web.Pages.Account.ProfileModel

@{
    ViewData["Title"] = "Profile";
    var isLecturer = User.IsInRole(EduChatbot.Models.Identity.ApplicationRoles.Lecturer);
    var accountLabel = isLecturer ? "Lecturer account" : "Student account";
    var backText = isLecturer ? "Back to dashboard" : "Back to chat";
    var userName = Model.ProfileInput.FullName;
    var initial = string.IsNullOrWhiteSpace(userName) ? "U" : userName.Trim()[0].ToString().ToUpperInvariant();

    if (!isLecturer)
    {
        ViewData["BodyClass"] = "student-profile";
        if (User.IsInRole(EduChatbot.Models.Identity.ApplicationRoles.Student))
        {
            Layout = "_StudentLayout";
        }
    }
}

<section class="account-profile-page">
    <header class="account-profile-hero">
        <div class="account-profile-hero-left">
            <div class="account-profile-avatar" aria-hidden="true">@initial</div>
            <div>
                <div class="account-profile-kicker" data-i18n="@(isLecturer ? "profile.lecturerAccount" : "profile.studentAccount")">@accountLabel</div>
                <h1>@userName</h1>
                <p class="account-profile-email-display">@Model.ProfileInput.Email</p>
            </div>
        </div>
        @if (isLecturer)
        {
            <a asp-page="/Documents/Dashboard" class="account-profile-back">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                <span data-i18n="profile.backDashboard">@backText</span>
            </a>
        }
        else
        {
            <a asp-page="/Chat/Index" class="account-profile-back">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                <span data-i18n="profile.backChat">@backText</span>
            </a>
        }
    </header>

    @if (TempData["ProfileMessage"] != null)
    {
        <div class="account-profile-alert">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <strong>@TempData["ProfileMessage"]</strong>
        </div>
    }

    <div class="account-profile-grid">
        <form method="post" asp-page-handler="UpdateProfile" class="account-profile-card">
            @Html.AntiForgeryToken()
            <div class="account-profile-card-header">
                <div class="account-profile-card-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M5 20a7 7 0 0 1 14 0"/></svg>
                </div>
                <div>
                    <div class="account-profile-kicker" data-i18n="profile.personalInfo">Personal information</div>
                    <h2 data-i18n="profile.title">Account details</h2>
                </div>
            </div>

            <div class="account-profile-field">
                <label asp-for="ProfileInput.FullName">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M5 20a7 7 0 0 1 14 0"/></svg>
                    <span data-i18n="profile.fullName">Full name</span>
                </label>
                <input asp-for="ProfileInput.FullName" maxlength="100" autocomplete="name" placeholder="Enter your full name" data-i18n-placeholder="profile.fullNamePlaceholder" />
                <span asp-validation-for="ProfileInput.FullName" class="account-profile-validation"></span>
            </div>

            <div class="account-profile-field">
                <label asp-for="ProfileInput.Email">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                    <span data-i18n="profile.email">Email login</span>
                </label>
                <input asp-for="ProfileInput.Email" readonly class="account-profile-readonly" />
            </div>

            <div class="account-profile-actions">
                <button type="submit" class="account-profile-primary-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                    <span data-i18n="profile.updateProfile">Save profile</span>
                </button>
            </div>
        </form>

        <form method="post" asp-page-handler="ChangePassword" class="account-profile-card">
            @Html.AntiForgeryToken()
            <div class="account-profile-card-header">
                <div class="account-profile-card-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                </div>
                <div>
                    <div class="account-profile-kicker" data-i18n="profile.kicker">Security</div>
                    <h2 data-i18n="profile.changePassword">Change password</h2>
                </div>
            </div>

            <div asp-validation-summary="All" class="account-profile-errors"></div>

            <div class="account-profile-field">
                <label asp-for="PasswordInput.CurrentPassword">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="16" r="1"/><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    <span data-i18n="profile.currentPassword">Current password</span>
                </label>
                <div class="pwd-input-wrapper">
                    <input asp-for="PasswordInput.CurrentPassword" autocomplete="current-password" placeholder="••••••••" />
                    <button type="button" class="pwd-toggle-btn" title="Show password" aria-label="Toggle password visibility">
                        <svg class="eye-open" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                            <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                        <svg class="eye-closed" style="display:none;" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                            <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/>
                            <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/>
                            <path d="M6.61 6.61A13.52 13.52 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/>
                            <line x1="2" x2="22" y1="2" y2="22"/>
                        </svg>
                    </button>
                </div>
            </div>

            <div class="account-profile-field">
                <label asp-for="PasswordInput.NewPassword">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21 2-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0 3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
                    <span data-i18n="profile.newPassword">New password</span>
                </label>
                <div class="pwd-input-wrapper">
                    <input asp-for="PasswordInput.NewPassword" autocomplete="new-password" placeholder="••••••••" />
                    <button type="button" class="pwd-toggle-btn" title="Show password" aria-label="Toggle password visibility">
                        <svg class="eye-open" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                            <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                        <svg class="eye-closed" style="display:none;" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                            <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/>
                            <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/>
                            <path d="M6.61 6.61A13.52 13.52 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/>
                            <line x1="2" x2="22" y1="2" y2="22"/>
                        </svg>
                    </button>
                </div>
            </div>

            <div class="account-profile-field">
                <label asp-for="PasswordInput.ConfirmPassword">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    <span data-i18n="profile.confirmPassword">Confirm new password</span>
                </label>
                <div class="pwd-input-wrapper">
                    <input asp-for="PasswordInput.ConfirmPassword" autocomplete="new-password" placeholder="••••••••" />
                    <button type="button" class="pwd-toggle-btn" title="Show password" aria-label="Toggle password visibility">
                        <svg class="eye-open" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                            <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                        <svg class="eye-closed" style="display:none;" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                            <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/>
                            <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/>
                            <path d="M6.61 6.61A13.52 13.52 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/>
                            <line x1="2" x2="22" y1="2" y2="22"/>
                        </svg>
                    </button>
                </div>
            </div>

            <div class="account-profile-actions">
                <button type="submit" class="account-profile-primary-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    <span data-i18n="profile.changePasswordBtn">Change password</span>
                </button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const forms = document.querySelectorAll("form");
            forms.forEach(form => {
                const toggleButtons = form.querySelectorAll(".pwd-toggle-btn");
                toggleButtons.forEach(button => {
                    button.addEventListener("click", function () {
                        const input = this.parentElement.querySelector("input");
                        if (!input) return;
                        
                        const eyeOpen = this.querySelector(".eye-open");
                        const eyeClosed = this.querySelector(".eye-closed");
                        
                        if (input.type === "password") {
                            input.type = "text";
                            if (eyeOpen) eyeOpen.style.display = "none";
                            if (eyeClosed) eyeClosed.style.display = "block";
                            this.title = "Hide password";
                        } else {
                            input.type = "password";
                            if (eyeOpen) eyeOpen.style.display = "block";
                            if (eyeClosed) eyeClosed.style.display = "none";
                            this.title = "Show password";
                        }
                    });
                });
            });
        });
    </script>
}
