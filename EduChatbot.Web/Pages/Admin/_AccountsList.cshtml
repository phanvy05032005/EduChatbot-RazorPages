@model EduChatbot.Web.Pages.Admin.AccountListPageModelBase
@{
    var isLecturer = Model.AccountType == EduChatbot.Models.Identity.ApplicationRoles.Lecturer;
}

<div class="admin-page">
    <div class="admin-page-header">
        <div>
            <div class="admin-kicker"><span data-i18n="admin.accounts.manage">Manage</span> · @Model.AccountType</div>
            <h1><span data-i18n="admin.accounts.manage">Manage</span> <span class="admin-serif">@Model.AccountType</span></h1>
            <p data-i18n="admin.accounts.viewSearchDesc">View, search, lock, unlock, and manage accounts.</p>
        </div>
        <a asp-page="/Admin/AccountForm" asp-route-accountType="@Model.AccountType" class="admin-primary-btn" data-i18n="admin.accounts.createAccount">Create account</a>
    </div>

    @if (TempData["AdminMessage"] != null)
    {
        <div class="admin-alert success">@TempData["AdminMessage"]</div>
    }

    @if (TempData["AdminError"] != null)
    {
        <div class="admin-alert danger">@TempData["AdminError"]</div>
    }

    <section class="admin-card mb-4" style="margin-bottom: 2rem;">
        <div class="admin-card-header">
            <h2>@(isLecturer ? "Import lecturer accounts via Excel" : "Import student accounts via Excel")</h2>
        </div>
        <div style="padding: 1.5rem;">
            <form method="post" asp-page-handler="Import" enctype="multipart/form-data" style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
                @Html.AntiForgeryToken()
                <input type="file" name="excelFile" accept=".xlsx" required style="padding: 0.5rem; border: 1px solid var(--admin-border); border-radius: 4px; background: var(--admin-bg);" />
                <button type="submit" class="admin-primary-btn" style="height: auto;" data-i18n="admin.accounts.uploadImport">Upload & Import</button>
            </form>
        </div>
    </section>

    <form method="get" class="admin-search">
        <div class="admin-search-input">
            <span aria-hidden="true">⌕</span>
            <input type="search" name="searchTerm" value="@Model.SearchTerm" placeholder="Search by ID, full name, or email" data-i18n-placeholder="admin.accounts.searchPlaceholder" />
        </div>
        <button type="submit" data-i18n="admin.accounts.search">Search</button>
    </form>

    <section id="accounts-table-card" class="admin-card admin-table-card">
        <div class="admin-card-header">
            <h2><span data-i18n="admin.accounts.list">List</span> @Model.AccountType</h2>
            <span>@Model.Accounts.Count <span data-i18n="admin.accounts.accounts">account(s)</span></span>
        </div>
        <div class="table-responsive">
            <table class="table admin-table mb-0">
                <thead>
                    <tr>
                        <th>@Model.AccountType ID</th>
                        <th data-i18n="admin.accounts.fullName">Full Name</th>
                        <th data-i18n="admin.accounts.email">Email</th>
                        @if (isLecturer)
                        {
                            <th data-i18n="admin.accounts.department">Department</th>
                        }
                        <th data-i18n="admin.accounts.status">Status</th>
                        <th data-i18n="admin.accounts.actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var account in Model.Accounts)
                    {
                        <tr>
                            <td><code>@account.Id</code></td>
                            <td>@account.FullName</td>
                            <td>@account.Email</td>
                            @if (isLecturer)
                            {
                                <td>@account.Department</td>
                            }
                            <td><span class="admin-status @(account.Status == "Active" ? "is-active" : "is-locked")">@account.Status</span></td>
                            <td class="admin-actions">
                                <a asp-page="/Admin/AccountForm" asp-route-id="@account.Id" title="Edit" data-i18n="admin.accounts.edit">Edit</a>
                                @if (isLecturer)
                                {
                                    <a asp-page="/Admin/LecturerDetail" asp-route-id="@account.Id" title="Details" data-i18n="admin.accounts.details">Details</a>
                                }
                                @if (account.Status == "Active")
                                {
                                    <form method="post" asp-page-handler="Lock" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@account.Id" />
                                        <button type="submit" data-i18n="admin.accounts.lock">Lock</button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" asp-page-handler="Unlock" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@account.Id" />
                                        <button type="submit" data-i18n="admin.accounts.unlock">Unlock</button>
                                    </form>
                                }
                                <form method="post" asp-page-handler="Delete" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@account.Id" />
                                    <button type="submit" class="danger" 
                                            data-i18n-confirm="admin.accounts.confirmDelete"
                                            data-i18n-confirm-en="Are you sure you want to delete this account?"
                                            data-i18n="admin.accounts.delete">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (Model.Accounts.Count == 0)
        {
            <div class="admin-empty-state" data-i18n="admin.accounts.noMatching">No matching accounts found.</div>
        }
    </section>
</div>
