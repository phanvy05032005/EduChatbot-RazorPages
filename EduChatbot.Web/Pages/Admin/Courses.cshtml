@page
@model EduChatbot.Web.Pages.Admin.CoursesModel
@{
    ViewData["Title"] = "Courses & Assignments";
    var assignedLecturerIds = Model.Courses
        .SelectMany(course => course.LecturerCourses)
        .Select(assignment => assignment.LecturerId)
        .ToHashSet();
    var availableLecturers = Model.Lecturers
        .Where(lecturer => !assignedLecturerIds.Contains(lecturer.Id))
        .ToList();
}

<div class="admin-page">
    <div class="admin-page-header">
        <div>
            <div class="admin-kicker" data-i18n="admin.courses.kicker">Courses</div>
            <h1><span data-i18n="admin.courses.title">Manage</span> <span class="admin-serif" data-i18n="admin.courses.titleSerif">Courses & Assignments</span></h1>
            <p data-i18n="admin.courses.subtitle">Create new courses and assign document upload permissions to lecturers.</p>
        </div>
    </div>

    @if (TempData["AdminMessage"] != null)
    {
        <div class="admin-alert success">@TempData["AdminMessage"]</div>
    }
    @if (TempData["AdminError"] != null)
    {
        <div class="admin-alert danger">@TempData["AdminError"]</div>
    }

    <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 2rem; margin-top: 1rem;">
        <div>
            <section class="admin-card">
                <div class="admin-card-header"><h2 data-i18n="admin.courses.createNew">Create New Course</h2></div>
                <div style="padding: 1.5rem;">
                    <form method="post" asp-page-handler="CreateCourse">
                        @Html.AntiForgeryToken()
                        <div style="margin-bottom: 1rem;">
                            <label style="display: block; margin-bottom: 0.5rem; font-weight: 500;" data-i18n="admin.courses.courseCode">Course Code</label>
                            <input type="text" name="code" placeholder="e.g. PRN222" required style="width: 100%; padding: 0.5rem; border: 1px solid var(--admin-border); border-radius: 4px; background: var(--admin-bg); color: var(--admin-text);" />
                        </div>
                        <div style="margin-bottom: 1rem;">
                            <label style="display: block; margin-bottom: 0.5rem; font-weight: 500;" data-i18n="admin.courses.courseName">Course Name</label>
                            <input type="text" name="name" placeholder="e.g. C# &amp; .NET Cloud" required style="width: 100%; padding: 0.5rem; border: 1px solid var(--admin-border); border-radius: 4px; background: var(--admin-bg); color: var(--admin-text);" />
                        </div>
                        <div style="margin-bottom: 1rem;">
                            <label style="display: block; margin-bottom: 0.5rem; font-weight: 500;" data-i18n="admin.courses.courseDesc">Course Description</label>
                            <textarea name="description" rows="6" required placeholder="e.g. ASP.NET Core, Razor Pages, Entity Framework Core" style="width: 100%; padding: 0.5rem; border: 1px solid var(--admin-border); border-radius: 4px; background: var(--admin-bg); color: var(--admin-text);"></textarea>
                        </div>
                        <button type="submit" class="admin-primary-btn" style="width: 100%;" data-i18n="admin.courses.createCourse">Create Course</button>
                    </form>
                </div>
            </section>

            <section class="admin-card" style="margin-top: 2rem;">
                <div class="admin-card-header"><h2 data-i18n="admin.courses.importExcel">Import Courses via Excel</h2></div>
                <div style="padding: 1.5rem;">
                    <form method="post" asp-page-handler="ImportCourses" enctype="multipart/form-data" style="display: flex; flex-direction: column; gap: 1rem;">
                        @Html.AntiForgeryToken()
                        <input type="file" name="excelFile" accept=".xlsx" required style="padding: 0.5rem; border: 1px solid var(--admin-border); border-radius: 4px; background: var(--admin-bg); color: var(--admin-text);" />
                        <div style="display: flex; gap: 0.5rem; width: 100%;">
                            <button type="submit" class="admin-primary-btn" style="flex: 1; height: auto;" data-i18n="admin.courses.importCourses">Import Courses</button>
                            <a asp-page-handler="DownloadTemplate" class="admin-primary-btn" style="background: rgba(228, 240, 246, 0.1); color: var(--admin-text); border: 1px solid var(--admin-border); display: inline-flex; align-items: center; justify-content: center; text-decoration: none; font-size: 0.9rem; height: auto; text-align: center;">Download Template</a>
                        </div>
                    </form>
                </div>
            </section>
        </div>

        <div>
            <section class="admin-card admin-table-card">
                <div class="admin-card-header"><h2 data-i18n="admin.courses.courseList">Course List</h2><span>@Model.Courses.Count course(s)</span></div>
                <div class="table-responsive">
                    <table class="table admin-table mb-0">
                        <thead><tr><th>Code</th><th>Course Name</th><th>Assigned Lecturers</th><th>Actions</th></tr></thead>
                        <tbody>
                            @foreach (var course in Model.Courses)
                            {
                                <tr>
                                    <td><code>@course.Code</code></td>
                                    <td><strong>@course.Name</strong><div style="margin-top:0.35rem; color:rgba(228, 240, 246, 0.68); font-size:0.82rem; line-height:1.4;">@(string.IsNullOrWhiteSpace(course.Description) ? "No description available." : course.Description)</div></td>
                                    <td>
                                        @if (course.LecturerCourses.Count == 0)
                                        {
                                            <em style="color: rgba(228, 240, 246, 0.65);">No lecturer assigned</em>
                                            <form method="post" asp-page-handler="AssignLecturer" style="display: flex; gap: 0.5rem; align-items: center; margin-top: 0.5rem;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="courseId" value="@course.Id" />
                                                <select name="lecturerId" required style="padding: 0.3rem; border: 1px solid var(--admin-border); border-radius: 4px; background: var(--admin-bg); color: var(--admin-text); font-size: 0.85rem;">
                                                    <option value="">-- Select lecturer --</option>
                                                    @if (availableLecturers.Count == 0)
                                                    {
                                                        <option value="" disabled>No unassigned lecturers available</option>
                                                    }
                                                    @foreach (var lecturer in availableLecturers)
                                                    {
                                                        <option value="@lecturer.Id">@lecturer.FullName (@lecturer.Email)</option>
                                                    }
                                                </select>
                                                <button type="submit" disabled="@(availableLecturers.Count == 0)" style="background: var(--admin-primary); color: white; border: none; padding: 0.3rem 0.6rem; border-radius: 4px; font-size: 0.8rem; cursor: pointer;">Assign</button>
                                            </form>
                                        }
                                        else
                                        {
                                            @foreach (var lc in course.LecturerCourses)
                                            {
                                                <div style="display: inline-flex; align-items: center; background: rgba(228, 240, 246, 0.08); padding: 0.2rem 0.5rem; border-radius: 4px; margin-right: 0.5rem; margin-bottom: 0.2rem; font-size: 0.85rem;">
                                                    <span style="margin-right: 0.3rem;">@(lc.Lecturer?.FullName ?? "N/A")</span>
                                                    <form method="post" asp-page-handler="RemoveLecturer" style="display:inline;">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="lecturerId" value="@lc.LecturerId" />
                                                        <input type="hidden" name="courseId" value="@course.Id" />
                                                        <button type="submit" style="background:none; border:none; color:red; cursor:pointer; font-weight:bold; font-size: 0.75rem; padding: 0 0.2rem;">x</button>
                                                    </form>
                                                </div>
                                            }
                                        }
                                    </td>
                                    <td>
                                        <form method="post" asp-page-handler="DeleteCourse">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@course.Id" />
                                            <button type="submit" class="danger" style="background:none; border:none; color:var(--admin-danger); cursor:pointer; font-size: 0.9rem;">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
    </div>
</div>
