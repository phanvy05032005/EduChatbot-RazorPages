@page
@model EduChatbot.Web.Pages.Student.Quizzes.ResultModel
@{
    Layout = "_StudentLayout";
    ViewData["Title"] = "Quiz Result: " + Model.Result.QuizTitle;
    ViewData["BodyClass"] = "student-shell";
    var isPassed = Model.Result.Score >= 50;
}

<div class="mb-4">
    <h2 class="fw-bold mb-1" style="color: #fff; font-size: 1.75rem;" data-i18n="quizzes.student.res.title">Quiz Results</h2>
    <p class="text-muted mb-0" data-i18n="quizzes.student.res.desc">Detailed review of your attempt performance.</p>
</div>

<div style="margin-bottom: 1.5rem;">
    <a asp-page="/Student/Quizzes/Index" class="btn btn-outline-light rounded-pill px-4" style="border: 1px solid rgba(255,255,255,0.2); color: #fff; text-decoration: none; font-size: 0.875rem;">
        ← Back to Quizzes
    </a>
</div>

<!-- Score Card Summary -->
<div class="student-card mb-4 text-center d-flex flex-column align-items-center justify-content-center" style="background: #181c26; border: 1px solid var(--edu-border); border-radius: 16px; padding: 2rem; display: flex; flex-direction: column; align-items: center; justify-content: center; margin-bottom: 2rem;">
    <h4 class="fw-bold text-white mb-3" style="font-size: 1.25rem;">@Model.Result.QuizTitle</h4>
    
    <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 130px; height: 130px; background: @(isPassed ? "rgba(40,167,69,0.1)" : "rgba(220,53,69,0.1)"); border: 4px solid @(isPassed ? "#28a745" : "#dc3545"); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;">
        <span style="font-size: 2rem; font-weight: bold; color: @(isPassed ? "#28a745" : "#dc3545");">
            @Model.Result.Score.ToString("0.0")%
        </span>
    </div>

    <h5 class="fw-bold" style="color: @(isPassed ? "#28a745" : "#dc3545"); margin-bottom: 0.5rem;" data-i18n="quizzes.student.res.@(isPassed ? "passed" : "failed")">
        @(isPassed ? "PASSED" : "FAILED")
    </h5>
    
    <p class="text-muted mb-0" style="font-size: 0.9rem;">
        <span data-i18n="student.result.answered1">You answered</span> <strong>@Model.Result.CorrectCount</strong> <span data-i18n="student.result.answered2">out of</span> <strong>@Model.Result.TotalQuestions</strong> <span data-i18n="student.result.answered3">questions correctly.</span>
    </p>
    <small style="color: var(--edu-text-muted); font-size: 0.75rem; margin-top: 0.5rem; display: block;">
        <span data-i18n="student.result.completedAt">Completed at:</span> @(Model.Result.SubmittedAt?.ToString("f") ?? "N/A")
    </small>
</div>

<!-- Detailed Questions Review -->
<h3 class="fw-bold text-white mb-3" style="font-size: 1.25rem; border-bottom: 2px solid var(--edu-border); padding-bottom: 0.5rem;" data-i18n="student.result.questionsReview">Questions Review</h3>

@for (int idx = 0; idx < Model.Result.Questions.Count; idx++)
{
    var q = Model.Result.Questions[idx];
    <div class="student-card mb-4" style="background: #181c26; border: 1px solid var(--edu-border); border-radius: 16px; padding: 1.5rem; margin-bottom: 1.5rem;">
        <div class="d-flex justify-content-between align-items-start mb-3" style="display: flex; justify-content: space-between; align-items: flex-start;">
            <h5 class="fw-bold text-white" style="font-size: 1.05rem; line-height: 1.5; margin-bottom: 0;">
                <span class="text-primary me-2" style="color: var(--edu-primary);">Q@(q.QuestionOrder).</span> @q.QuestionText
            </h5>
            <span class="badge" style="background: @(q.IsCorrect ? "rgba(40,167,69,0.1)" : "rgba(220,53,69,0.1)"); color: @(q.IsCorrect ? "#28a745" : "#dc3545"); padding: 0.25rem 0.6rem; border-radius: 4px; font-size: 0.8rem; font-weight: bold; flex-shrink: 0;" data-i18n="quizzes.student.res.@(q.IsCorrect ? "correctBadge" : "incorrectBadge")">
                @(q.IsCorrect ? "Correct" : "Incorrect")
            </span>
        </div>

        <div style="margin-left: 1.5rem; display: flex; flex-direction: column; gap: 0.8rem; margin-bottom: 1.2rem;">
            @foreach (var opt in q.Options)
            {
                var isSelected = opt.OptionId == q.SelectedOptionId;
                var isCorrectOption = opt.OptionId == q.CorrectOptionId;

                var bgStyle = "rgba(228, 240, 246, 0.02)";
                var borderStyle = "var(--edu-border)";
                var labelBg = "rgba(228, 240, 246, 0.08)";

                if (isCorrectOption)
                {
                    bgStyle = "rgba(40, 167, 69, 0.1)";
                    borderStyle = "rgba(40, 167, 69, 0.3)";
                    labelBg = "#28a745";
                }
                else if (isSelected)
                {
                    bgStyle = "rgba(220, 53, 69, 0.1)";
                    borderStyle = "rgba(220, 53, 69, 0.3)";
                    labelBg = "#dc3545";
                }

                <div style="display: flex; align-items: center; gap: 0.8rem; padding: 0.8rem 1.2rem; border-radius: 10px; background: @bgStyle; border: 1px solid @borderStyle;">
                    <span style="font-weight: bold; background: @labelBg; color: #fff; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; border-radius: 6px; font-size: 0.85rem;">
                        @opt.Label
                    </span>
                    <span style="color: var(--edu-text); font-size: 0.95rem;">@opt.OptionText</span>
                    
                    @if (isCorrectOption)
                    {
                        <span style="margin-left: auto; font-size: 0.8rem; font-weight: bold; color: #28a745; display: flex; align-items: center; gap: 0.25rem;">
                            <i class="bi bi-check-circle-fill"></i> <span data-i18n="quizzes.student.res.correctOption">Correct Option</span>
                        </span>
                    }
                    else if (isSelected)
                    {
                        <span style="margin-left: auto; font-size: 0.8rem; font-weight: bold; color: #dc3545; display: flex; align-items: center; gap: 0.25rem;">
                            <i class="bi bi-x-circle-fill"></i> <span data-i18n="quizzes.student.res.yourAnswer">Your Answer</span>
                        </span>
                    }
                </div>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(q.Explanation))
        {
            <div style="margin-left: 1.5rem; padding: 0.8rem 1rem; background: rgba(0, 123, 255, 0.05); border-left: 4px solid var(--edu-primary); border-radius: 0 8px 8px 0; font-size: 0.9rem; color: var(--edu-text-muted);">
                <strong data-i18n="quizzes.lecturer.rev.explanation">Explanation: </strong>@q.Explanation
            </div>
        }
    </div>
}

@if (Request.Query["submitted"] == "true")
{
    @section Scripts {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                if (window.Swal) {
                    Swal.fire({
                        title: window.EduI18n && EduI18n.getLang() === 'vi' ? 'Nộp bài thành công!' : 'Quiz Submitted!',
                        text: window.EduI18n && EduI18n.getLang() === 'vi' ? 'Chúc mừng bạn đã hoàn thành bài thi. Hãy xem kết quả chi tiết bên dưới.' : 'Congratulations on completing the quiz. Check your detailed results below.',
                        icon: 'success',
                        background: '#181c26',
                        color: '#fff',
                        confirmButtonColor: '#007bff',
                        confirmButtonText: 'OK'
                    });
                }
            });
        </script>
    }
}
