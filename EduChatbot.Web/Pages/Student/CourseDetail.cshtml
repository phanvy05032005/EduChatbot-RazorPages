@page
@model EduChatbot.Web.Pages.Student.CourseDetailModel
@{
    Layout = "_StudentLayout";
    ViewData["Title"] = Model.Course?.Name ?? "Course Details";
    ViewData["BodyClass"] = "student-shell";
}

@if (Model.Course != null)
{
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a class="text-decoration-none" asp-page="/Student/Courses" data-i18n="student.coursedetail.breadcrumb_courses">Courses</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Course.Code</li>
        </ol>
    </nav>

    <!-- Header Panel -->
    <div class="student-card mb-5 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-4">
        <div>
            <div class="d-flex align-items-center gap-2 mb-2">
                <span class="badge bg-primary bg-opacity-10 text-primary fw-bold fs-6">@Model.Course.Code</span>
                <span class="badge bg-secondary bg-opacity-10 text-muted" data-i18n="student.coursedetail.core_syllabus">Core Syllabus</span>
            </div>
            <h2 class="fw-bold mb-2">@Model.Course.Name</h2>
            <p class="text-muted mb-0">@Model.Course.Description</p>
        </div>
        <div class="flex-shrink-0">
            <a class="btn btn-primary rounded-pill px-4 py-2 text-white fw-semibold d-flex align-items-center gap-2 shadow animate-btn" asp-page="/Student/Chat" asp-route-courseId="@Model.Course.Id">
                <i class="bi bi-chat-dots-fill fs-5"></i>
                <span data-i18n="student.coursedetail.btn_start_chat">Start Chat with Course</span>
            </a>
        </div>
    </div>

    <!-- Document List Section -->
    <section>
        <h3 class="fw-bold fs-4 mb-3" data-i18n="student.coursedetail.section_title">Syllabus & Documents</h3>

        @if (Model.Documents.Count == 0)
        {
            <div class="student-card empty-state-panel text-center py-5">
                <div class="empty-state-mark d-flex align-items-center justify-content-center">
                    <i class="bi bi-folder-x fs-2"></i>
                </div>
                <h5 class="fw-bold" data-i18n="student.coursedetail.course_not_found">No documents available</h5>
                <p class="text-muted" data-i18n="student.coursedetail.course_not_found_desc">There are no approved document files uploaded for this course yet.</p>
            </div>
        }
        else
        {
            <div class="student-card p-0 overflow-hidden">
                <div class="table-responsive">
                    <table class="student-table">
                        <thead>
                            <tr>
                                <th data-i18n="student.coursedetail.table_file_name">File Name</th>
                                <th data-i18n="student.coursedetail.table_uploaded_date">Uploaded Date</th>
                                <th data-i18n="student.coursedetail.table_size">Size</th>
                                <th class="text-end" data-i18n="student.coursedetail.table_actions">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var doc in Model.Documents)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="bi bi-file-earmark-pdf text-danger fs-5"></i>
                                            <span class="fw-semibold">@doc.FileName</span>
                                        </div>
                                    </td>
                                    <td class="text-muted" style="font-size: 0.85rem;">@doc.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-muted" style="font-size: 0.85rem;">
                                        @((doc.FileSize / 1024.0).ToString("N1")) KB
                                    </td>
                                    <td class="text-end">
                                        <a class="btn btn-outline-primary btn-sm rounded-pill me-1 animate-btn" href="@doc.FilePath" target="_blank" data-i18n="student.dashboard.btn_view">View</a>
                                        <a class="btn btn-primary btn-sm rounded-pill text-white animate-btn" asp-page="/Student/Chat" asp-route-courseId="@Model.Course.Id" asp-route-documentId="@doc.Id" data-i18n="student.dashboard.btn_ask_ai">Ask AI</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </section>
}
else
{
    <div class="student-card empty-state-panel text-center py-5">
        <div class="empty-state-mark d-flex align-items-center justify-content-center">
            <i class="bi bi-exclamation-triangle fs-2"></i>
        </div>
        <h5 class="fw-bold" data-i18n="student.coursedetail.course_not_found">Course not found</h5>
        <p class="text-muted" data-i18n="student.coursedetail.course_not_found_desc">The requested course could not be loaded. Please return to the library.</p>
        <a class="btn btn-primary btn-sm rounded-pill text-white mt-2" asp-page="/Student/Courses" data-i18n="student.coursedetail.btn_back">Back to Library</a>
    </div>
}
