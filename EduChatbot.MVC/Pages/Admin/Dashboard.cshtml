@page
@model EduChatbot.MVC.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="admin-page">
    <div class="admin-page-header">
        <div>
            <div class="admin-kicker" data-i18n="admin.dashboard.kicker">System overview</div>
            <h1><span data-i18n="admin.dashboard.title">System</span> <span class="admin-serif" data-i18n="admin.dashboard.titleSerif">Overview</span></h1>
            <p data-i18n="admin.dashboard.subtitle">Monitor metrics and activity across the EduChatbot system.</p>
        </div>
        <a asp-page="/Admin/Dashboard" class="admin-secondary-btn" data-i18n="admin.dashboard.refresh">Refresh</a>
    </div>

    <div class="admin-metric-grid">
        <article class="admin-card admin-metric-card success"><strong>@Model.TotalStudents.ToString("N0")</strong><span>Total Students</span></article>
        <article class="admin-card admin-metric-card accent"><strong>@Model.TotalLecturers.ToString("N0")</strong><span>Total Lecturers</span></article>
        <article class="admin-card admin-metric-card light"><strong>@Model.TotalDocuments.ToString("N0")</strong><span>Documents in System</span></article>
        <article class="admin-card admin-metric-card warning"><strong>@Model.TotalChatQuestions.ToString("N0")</strong><span>Total Chat Questions</span></article>
    </div>

    <section class="admin-card admin-activity-card">
        <div class="admin-card-header">
            <h2><span aria-hidden="true">⌁</span> <span data-i18n="admin.dashboard.recentActivities">Recent activities</span></h2>
            <span class="admin-live-pill" data-i18n="admin.dashboard.live">Live</span>
        </div>
        <ul class="activity-list">
            @foreach (var activity in Model.RecentActivities)
            {
                <li><span class="activity-icon" aria-hidden="true">✦</span><div><strong>@activity</strong><small>Updated just now · Admin</small></div></li>
            }
        </ul>
    </section>
</div>
