<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduChatbot</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EduChatbot.MVC.styles.css" asp-append-version="true" />
</head>
<body class="app-shell">
@if (User.IsInRole("Admin"))
{
    <div class="admin-shell">
        <aside class="admin-sidebar">
            <div class="admin-brand">
                <span class="admin-brand-mark">EC</span>
                <div>
                    <strong>EduChatbot</strong>
                    <small>Admin Panel</small>
                </div>
            </div>
            <nav class="admin-menu">
                <a asp-controller="Admin" asp-action="Dashboard">Dashboard</a>
                <a asp-controller="Admin" asp-action="Students">Student Accounts</a>
                <a asp-controller="Admin" asp-action="Lecturers">Lecturer Accounts</a>
                <a asp-controller="Admin" asp-action="Roles">Role Management</a>
                <a asp-controller="Admin" asp-action="System">System Management</a>
                <a asp-controller="Admin" asp-action="Statistics">Statistics</a>
            </nav>
            <form asp-controller="Account" asp-action="Logout" method="post" class="admin-logout">
                @Html.AntiForgeryToken()
                <button type="submit">Logout</button>
            </form>
        </aside>
        <div class="admin-content">
            <header class="admin-topbar">
                <div>
                    <span>Academic Chatbot System</span>
                    <strong>@ViewData["Title"]</strong>
                </div>
                <div class="admin-user">@User.Identity?.Name</div>
            </header>
            <main role="main" class="admin-main">
                @RenderBody()
            </main>
        </div>
    </div>
}
else
{
    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Lecturer"))
    {
        <div class="role-shell">
            <aside class="role-sidebar">
                <div class="role-brand">
                    <span class="role-brand-mark">LE</span>
                    <div>
                        <strong>EduChatbot</strong>
                        <small>Lecturer Portal</small>
                    </div>
                </div>
                <nav class="role-menu">
                    <a asp-controller="Documents" asp-action="Dashboard">Dashboard</a>
                    <a asp-controller="Documents" asp-action="Index">Learning Materials</a>
                    <a asp-controller="Documents" asp-action="Upload">Upload Document</a>
                </nav>
                <form asp-controller="Account" asp-action="Logout" method="post" class="role-logout">
                    @Html.AntiForgeryToken()
                    <button type="submit">Logout</button>
                </form>
            </aside>
            <div class="role-content">
                <header class="role-topbar">
                    <div>
                        <span>Academic Chatbot System</span>
                        <strong>@ViewData["Title"]</strong>
                    </div>
                    <div class="role-user">@User.Identity?.Name</div>
                </header>
                <main role="main" class="role-main">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom mb-4">
            <div class="container">
                <a class="navbar-brand fw-semibold" asp-area="" asp-controller="Documents" asp-action="Dashboard">EduChatbot</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.IsInRole("Student"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Chat" asp-action="Index">Chat</a>
                            </li>
                        }
                        @if (User.IsInRole("Lecturer"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Documents" asp-action="Dashboard">Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Documents" asp-action="Index">Documents</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Documents" asp-action="Upload">Upload</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link">@User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link nav-link">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    }
}

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
