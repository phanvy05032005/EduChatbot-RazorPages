@model EduChatbot.MVC.Models.AdminAccountFormViewModel

@{
    ViewData["Title"] = Model.IsEdit ? "Edit Account" : $"Create {Model.AccountType} Account";
    var formAction = Model.IsEdit ? "EditAccount" : "CreateAccount";
    var returnAction = Model.AccountType == EduChatbot.Models.Identity.ApplicationRoles.Lecturer
        ? "Lecturers"
        : "Students";
}

<div class="admin-page-header">
    <div>
        <h1>@ViewData["Title"]</h1>
        <p>Maintain @Model.AccountType.ToLowerInvariant() identity information.</p>
    </div>
</div>

<form asp-controller="Admin" asp-action="@formAction" method="post" class="admin-card admin-form">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <input asp-for="AccountType" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="FullName" class="form-label">Full Name</label>
        <input asp-for="FullName" class="form-control" maxlength="100" />
        <span asp-validation-for="FullName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label">Email</label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    @if (!Model.IsEdit)
    {
        <div class="mb-3">
            <label asp-for="Password" class="form-label">Password</label>
            <input asp-for="Password" class="form-control" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
    }

    <div class="d-flex gap-2">
        <button type="submit" class="admin-primary-btn">Save Account</button>
        <a asp-controller="Admin"
           asp-action="@returnAction"
           class="admin-secondary-btn">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
