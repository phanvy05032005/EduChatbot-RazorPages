@model List<EduChatbot.MVC.Models.AdminRolePermissionViewModel>

@{
    ViewData["Title"] = "Role Management";
    var roleMeta = new Dictionary<string, (string Tone, string Icon, string Description)>
    {
        ["Student"] = ("success", "♙", "Hỏi đáp về tài liệu đã upload, xem lịch sử trò chuyện cá nhân."),
        ["Lecturer"] = ("accent", "♧", "Upload, quản lý và chỉnh sửa tài liệu giảng dạy."),
        ["Admin"] = ("light", "◇", "Toàn quyền quản trị hệ thống và tài khoản.")
    };
}

<div class="admin-page">
    <div class="admin-page-header">
        <div>
            <div class="admin-kicker">Access · Roles</div>
            <h1>Phân <span class="admin-serif">quyền</span></h1>
            <p>Các vai trò trong hệ thống và phạm vi quyền hạn tương ứng.</p>
        </div>
    </div>

    <div class="role-grid">
        @foreach (var role in Model)
        {
            var meta = roleMeta.TryGetValue(role.RoleName, out var value)
                ? value
                : (Tone: "accent", Icon: "◇", Description: "Role permissions");

            <section class="admin-card role-card @meta.Tone">
                <div class="role-card-top">
                    <span class="role-icon" aria-hidden="true">@meta.Icon</span>
                    <div>
                        <strong>@role.Permissions.Count</strong>
                        <small>Permissions</small>
                    </div>
                </div>
                <h2>@role.RoleName</h2>
                <p>@meta.Description</p>
                <div class="permission-block">
                    <div class="permission-title">Permissions</div>
                    <ul class="permission-list">
                        @foreach (var permission in role.Permissions)
                        {
                            <li>@permission</li>
                        }
                    </ul>
                </div>
            </section>
        }
    </div>
</div>
