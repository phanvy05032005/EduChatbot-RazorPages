@{
    ViewData["Title"] = "Home";
}

<section class="public-home">
    <div class="public-home-panel">
        <div class="public-kicker">EduChatbot</div>
        <h1>Academic document assistant</h1>
        <p>
            Upload learning materials, index them with embeddings, and let students ask questions with clear source references.
        </p>
        <div class="public-actions">
            <a asp-controller="Account" asp-action="Login" class="btn btn-primary">Sign in</a>
            <a asp-controller="Account" asp-action="Register" class="btn btn-outline-primary">Create account</a>
        </div>
    </div>
</section>
