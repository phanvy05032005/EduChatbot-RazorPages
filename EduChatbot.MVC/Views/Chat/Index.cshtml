@model List<EduChatbot.Models.ChatConversation>

@{
    ViewData["Title"] = "Chat";
    Layout = "_Layout";
    ViewData["ActiveConversationId"] = null;
    ViewData["BodyClass"] = "chat-layout";
}

<section class="chat-shell">
    <partial name="_StudentSidebar" model="Model" view-data="ViewData" />

    <main class="chat-main chat-list-main">
        <header class="chat-main-header">
            <div class="chat-header-topic">
                <span>EDU &middot; CHAT</span>
                <strong>Cuộc trò chuyện</strong>
            </div>
            <div class="chat-mode-pill">
                <span aria-hidden="true"></span>
                Academic mode
            </div>
        </header>

        <div class="chat-list-panel">
            <div class="chat-list-heading">
                <div class="chat-kicker">Your conversations</div>
                <h1>Học tập, khám phá,<br />với tài liệu của bạn.</h1>
            </div>

            <a asp-controller="Chat" asp-action="Conversation" class="chat-new-card">
                <span class="chat-new-mark">+</span>
                <span class="chat-new-copy">
                    <strong>New Chat</strong>
                    <small>Bắt đầu cuộc hội thoại mới với AI</small>
                </span>
                <span class="chat-new-arrow" aria-hidden="true">-&gt;</span>
            </a>

            @if (Model.Count == 0)
            {
                <div class="chat-empty-panel">
                    <div class="chat-empty-mark">AI</div>
                    <h2>Start your first conversation</h2>
                    <p>Bạn chưa có cuộc trò chuyện nào. Hãy tạo cuộc trò chuyện mới để bắt đầu khám phá tài liệu.</p>
                </div>
            }
            else
            {
                <div class="chat-conversation-list" aria-label="Conversation list">
                    @foreach (var conv in Model)
                    {
                        <a asp-controller="Chat" asp-action="Conversation" asp-route-id="@conv.Id" class="conversation-card">
                            <span class="conversation-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false">
                                    <path d="M5 5.5h14v10H8.5L5 19V5.5Z" />
                                </svg>
                            </span>
                            <span class="conversation-copy">
                                <strong>@conv.Title</strong>
                                <small>Updated @conv.UpdatedAt.ToLocalTime().ToString("HH:mm dd/MM/yyyy")</small>
                            </span>
                            <span class="conversation-arrow" aria-hidden="true">-&gt;</span>
                        </a>
                    }
                </div>
            }
        </div>
    </main>
</section>

@section Scripts {
    <script src="~/js/chat.js" asp-append-version="true"></script>
}
